---
import { Image } from 'astro:assets';
import { photos } from '../data/photos.ts';

// The hero photo. The dark droplet is gorgeous and sets the tone.
const heroPhoto = photos.find((p) => p.id === '24')!;
---

<section class="hero">
  <div class="hero-image">
    <Image
      src={heroPhoto.src}
      alt={heroPhoto.title}
      widths={[800, 1200, 1800, 2400]}
      sizes="100vw"
      loading="eager"
      format="webp"
      quality={88}
    />
    <div class="vignette"></div>
  </div>

  <div class="hero-content">
    <div class="container">
      <p class="eyebrow">Photographs · 2024 — 2025</p>
      <h1>
        <span class="line">Light, held</span>
        <span class="line"><em>briefly.</em></span>
      </h1>
      <p class="lede">
        A field journal by <strong>Nitish Devadiga</strong> — quiet macro,
        burning landscapes, dark rooms, and a few things that asked to be
        photographed before disappearing.
      </p>

      <div class="hero-meta-row">
        <div class="meta">
          <div>
            <span class="num">23</span>
            <span class="lbl">photographs</span>
          </div>
          <div>
            <span class="num">07</span>
            <span class="lbl">moods</span>
          </div>
          <div>
            <span class="num">02</span>
            <span class="lbl">years</span>
          </div>
        </div>

        <a class="scroll-cue" href="#featured">
          <span>Begin</span>
          <span class="arrow">↓</span>
        </a>
      </div>
    </div>
  </div>

  <!-- attribution badge for the hero photo -->
  <div class="hero-credit">
    <span class="num">No. {heroPhoto.id}</span>
    <span class="title"><em>{heroPhoto.title}</em></span>
  </div>
</section>

<style lang="scss">
  @use '../styles/tokens' as *;

  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    z-index: 1;

    :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      animation: heroBreathe 16s ease-in-out infinite alternate;
    }
  }

  // Subtle, slow zoom — makes the hero feel alive, like the camera is breathing
  @keyframes heroBreathe {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.06);
    }
  }

  .vignette {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      // dark fade at top to make the nav readable
      linear-gradient(to bottom, rgba(10, 8, 7, 0.85) 0%, rgba(10, 8, 7, 0.2) 25%, transparent 45%),
      // dark fade at bottom for text legibility + section transition
      linear-gradient(to top, rgba(10, 8, 7, 0.95) 0%, rgba(10, 8, 7, 0.7) 20%, transparent 55%),
      // very subtle vignette on the sides
      radial-gradient(ellipse at center, transparent 40%, rgba(10, 8, 7, 0.5) 100%);
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    padding-bottom: $s-9;
    pointer-events: none; // so the hero image is still clickable underneath

    // re-enable pointer events on actual content
    .container > * {
      pointer-events: auto;
    }
  }

  .eyebrow {
    margin-bottom: $s-5;
    color: $bone;
    opacity: 0.7;
  }

  h1 {
    font-family: $serif;
    font-size: clamp(64px, 11vw, 180px);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin-bottom: $s-5;
    color: $bone;
    max-width: 14ch;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.6);

    .line {
      display: block;
      opacity: 0;
      transform: translateY(30px);
      animation: rise 1s $ease-out forwards;

      &:nth-child(1) {
        animation-delay: 0.15s;
      }
      &:nth-child(2) {
        animation-delay: 0.35s;
      }
    }

    em {
      font-style: italic;
      font-weight: 400;
      color: $rust;
    }
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .lede {
    font-size: 18px;
    line-height: 1.6;
    color: $bone;
    opacity: 0.85;
    max-width: 540px;
    margin-bottom: $s-7;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.7);
    opacity: 0;
    animation: fadeIn 1s $ease-out 0.6s forwards;

    strong {
      font-weight: 400;
      color: $bone;
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 0.85;
    }
  }

  .hero-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: $s-6;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeIn 1s $ease-out 0.8s forwards;
  }

  .meta {
    display: flex;
    gap: $s-7;
    color: $bone;

    @include mobile {
      gap: $s-5;
    }

    div {
      display: flex;
      flex-direction: column;
      gap: $s-1;
    }

    .num {
      font-family: $serif;
      font-size: 32px;
      font-weight: 300;
      letter-spacing: -0.02em;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.7);
    }

    .lbl {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: $bone;
      opacity: 0.65;
    }
  }

  .scroll-cue {
    display: inline-flex;
    align-items: center;
    gap: $s-3;
    font-family: $mono;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: $bone;
    border: 1px solid rgba($bone, 0.3);
    padding: $s-3 $s-5;
    border-radius: 999px;
    transition: all $dur-base $ease;
    backdrop-filter: blur(8px);
    background: rgba(10, 8, 7, 0.3);

    .arrow {
      transition: transform $dur-base $ease;
    }

    &:hover {
      border-color: $rust;
      color: $rust;
      .arrow {
        transform: translateY(4px);
      }
    }
  }

  // small caption tag in the corner, like a museum label
  .hero-credit {
    position: absolute;
    top: 50%;
    right: $s-6;
    z-index: 4;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: right center;
    display: flex;
    gap: $s-4;
    align-items: baseline;
    color: $bone;
    opacity: 0.6;

    .num {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
    }
    .title {
      font-family: $serif;
      font-size: 13px;
      em {
        font-style: italic;
      }
    }

    @include mobile {
      display: none;
    }
  }

  @include mobile {
    .hero {
      min-height: 100svh;
    }
    .hero-content {
      padding-bottom: $s-7;
    }
    .hero-meta-row {
      flex-direction: column;
      align-items: flex-start;
      gap: $s-4;
    }
  }
</style>
